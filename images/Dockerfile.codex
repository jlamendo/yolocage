# yolocage — codex cage image.
#
# Identical layer structure to Dockerfile.claude except the npm install
# pulls codex instead of claude-code. The base + python + mitmproxy +
# addon layers are byte-identical to claude so docker layer cache reuses
# them when both images are built in the same context.
#
# Build:
#   docker build -f images/Dockerfile.codex -t yolocage/codex:dev .

FROM ubuntu:24.04

ARG DEBIAN_FRONTEND=noninteractive

# ─── Stage 1: base apt deps ────────────────────────────────────────
RUN apt-get update \
 && apt-get install -y --no-install-recommends \
      ca-certificates \
      curl \
      git \
      tmux \
      tini \
      gnupg \
      less \
      vim \
      jq \
      python3 \
      python3-pip \
      gosu \
      netcat-openbsd \
 && rm -rf /var/lib/apt/lists/*

# ─── Stage 2: node 22 via NodeSource ───────────────────────────────
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
 && apt-get install -y --no-install-recommends nodejs \
 && rm -rf /var/lib/apt/lists/* \
 && node --version && npm --version

# ─── Stage 3: mitmproxy + scrubber lib ─────────────────────────────
ARG MITMPROXY_VERSION=11.1.3
RUN pip install --no-cache-dir --break-system-packages \
      "mitmproxy==${MITMPROXY_VERSION}" \
 && mitmdump --version | head -1

COPY addons/scrub_secrets.py     /opt/yolocage/ssproxy/scrub_secrets.py
COPY addons/gitleaks_patterns.py /opt/yolocage/ssproxy/gitleaks_patterns.py
COPY addons/addon.py             /opt/yolocage/ssproxy/addon.py

# ─── Stage 4: codex CLI ────────────────────────────────────────────
# @openai/codex; pinned to a current stable release.
ARG CODEX_VERSION=0.139.0
RUN npm install -g "@openai/codex@${CODEX_VERSION}" \
 && codex --version

# ─── Stage 5: entrypoint ───────────────────────────────────────────
COPY images/entrypoint.sh /usr/local/bin/yc-entrypoint
RUN chmod 0755 /usr/local/bin/yc-entrypoint

# ─── Stage 6: non-root agent user ──────────────────────────────────
# ubuntu:24.04 ships with a pre-existing `ubuntu` user at uid 1000 —
# remove it before adding `agent` so the uid is free.
RUN userdel -r ubuntu 2>/dev/null || true \
 && groupadd --system --gid 1000 agent \
 && useradd --system --uid 1000 --gid agent \
      --home-dir /home/agent --create-home --shell /bin/bash agent \
 && install -d -m 0755 -o agent -g agent /home/agent/.codex \
 && install -d -m 0755 -o agent -g agent /home/agent/.mitmproxy \
 && install -d -m 0755 -o agent -g agent /workspace

WORKDIR /workspace

ENTRYPOINT ["/usr/bin/tini", "--", "/usr/local/bin/yc-entrypoint"]
# `--full-auto` is codex's bypass-permissions equivalent in 0.139.
CMD ["codex", "--full-auto"]
