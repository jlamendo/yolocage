# yolocage — codex cage image.
#
# Identical to Dockerfile.claude except the npm install pulls codex
# instead of claude-code. Cache-friendly with the claude image: every
# layer above the agent-CLI install is shared.

FROM node:22-bookworm

# ─── Stage 1: base apt deps ────────────────────────────────────────
RUN apt-get update \
 && apt-get install -y --no-install-recommends \
      ca-certificates \
      curl \
      git \
      tmux \
      tini \
      gnupg \
      less \
      vim \
      jq \
      python3 \
      python3-pip \
      gosu \
      netcat-openbsd \
 && rm -rf /var/lib/apt/lists/*

# ─── Stage 2: mitmproxy + scrubber lib ─────────────────────────────
ARG MITMPROXY_VERSION=11.0.2
RUN pip install --no-cache-dir --break-system-packages \
      "mitmproxy==${MITMPROXY_VERSION}" \
 && mitmdump --version | head -1

COPY addons/scrub_secrets.py     /opt/yolocage/ssproxy/scrub_secrets.py
COPY addons/gitleaks_patterns.py /opt/yolocage/ssproxy/gitleaks_patterns.py
COPY addons/addon.py             /opt/yolocage/ssproxy/addon.py

# ─── Stage 3: codex CLI ────────────────────────────────────────────
# @openai/codex; current npm `latest` per cork's pinning.
ARG CODEX_VERSION=0.139.0
RUN npm install -g "@openai/codex@${CODEX_VERSION}" \
 && codex --version

# ─── Stage 4: entrypoint ───────────────────────────────────────────
COPY images/entrypoint.sh /usr/local/bin/yc-entrypoint
RUN chmod 0755 /usr/local/bin/yc-entrypoint

# ─── Stage 5: non-root agent user ──────────────────────────────────
# node:22-bookworm ships with a pre-existing `node` user at uid 1000 —
# remove it before adding `agent` so the uid is free.
RUN userdel -r node 2>/dev/null || true \
 && groupadd --system --gid 1000 agent \
 && useradd --system --uid 1000 --gid agent \
      --home-dir /home/agent --create-home --shell /bin/bash agent \
 && install -d -m 0755 -o agent -g agent /home/agent/.codex \
 && install -d -m 0755 -o agent -g agent /home/agent/.mitmproxy \
 && install -d -m 0755 -o agent -g agent /workspace

WORKDIR /workspace

ENTRYPOINT ["/usr/bin/tini", "--", "/usr/local/bin/yc-entrypoint"]
# `--full-auto` is codex's bypass-permissions equivalent in 0.139.
CMD ["codex", "--full-auto"]
